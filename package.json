{
  "name": "cal2work",
  "version": "1.1.0",
  "description": "Browse Apple and Google calendar events and export a curated selection to Outlook-compatible .ics",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": "server.mjs",
  "scripts": {
    "dev": "vite",
    "server": "node server.mjs",
    "dev:all": "concurrently -n vite,proxy -c cyan,yellow \"npm run dev\" \"npm run server\"",
    "build": "tsc -b && vite build",
    "build:prod": "node build.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@tailwindcss/vite": "^4.3.0",
    "axios": "^1.16.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "ical.js": "^2.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
